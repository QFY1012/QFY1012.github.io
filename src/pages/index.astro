<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>屈非塬 · HCI Researcher</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0e0e0e;
      --surface: #161616;
      --border: #2a2a2a;
      --text: #e8e8e8;
      --muted: #888;
      --accent: #7c6ff7;
      --accent2: #5dcaa5;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.7;
    }

    /* ── 导航 ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 2rem;
      background: rgba(14,14,14,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 0.5px solid var(--border);
    }
    .logo { font-weight: 600; font-size: 1rem; letter-spacing: 0.05em; }
    .logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; transition: color .2s; }
    .nav-links a:hover { color: var(--text); }

    /* ── Hero ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 2rem 4rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .badge {
      display: inline-block;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent2);
      border: 0.5px solid var(--accent2);
      padding: 4px 12px;
      border-radius: 999px;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }
    .hero h1 .highlight { color: var(--accent); }
    .hero p {
      font-size: 1.1rem;
      color: var(--muted);
      max-width: 520px;
      margin-bottom: 2.5rem;
    }
    .cta-group { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      padding: 0.75rem 1.75rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      transition: all .2s;
      cursor: pointer;
      border: none;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #6a5fe0; transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--text); border: 0.5px solid var(--border); }
    .btn-ghost:hover { border-color: var(--muted); }

    /* ── 通用 Section ── */
    section {
      max-width: 800px;
      margin: 0 auto;
      padding: 5rem 2rem;
      border-top: 0.5px solid var(--border);
    }
    .section-label {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    h2 {
      font-size: 1.8rem;
      font-weight: 600;
      margin-bottom: 2.5rem;
      letter-spacing: -0.01em;
    }

    /* ── 技能 ── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }
    .skill-card {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
      transition: border-color .2s;
    }
    .skill-card:hover { border-color: var(--accent); }
    .skill-card h3 { font-size: 0.85rem; color: var(--accent2); margin-bottom: 0.75rem; font-weight: 500; letter-spacing: 0.05em; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-size: 0.78rem;
      padding: 3px 10px;
      border-radius: 4px;
      background: #1e1e1e;
      color: var(--muted);
      border: 0.5px solid var(--border);
    }

    /* ── 经历 ── */
    .timeline { display: flex; flex-direction: column; gap: 2rem; }
    .tl-item {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 1.5rem;
    }
    .tl-date { font-size: 0.82rem; color: var(--muted); padding-top: 4px; }
    .tl-content h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .tl-content .company { font-size: 0.85rem; color: var(--accent); margin-bottom: 0.5rem; }
    .tl-content p { font-size: 0.9rem; color: var(--muted); }

    /* ── 项目 ── */
    .projects-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .project-group-label {
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0.5rem 0 0.25rem;
      border-bottom: 0.5px solid var(--border);
      margin-bottom: 0.25rem;
      margin-top: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .project-group-label:first-child { margin-top: 0; }
    .project-card {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      transition: all .2s;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 2rem;
    }
    .project-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .project-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .project-card .project-sub { font-size: 0.82rem; color: var(--accent2); margin-bottom: 0.5rem; }
    .project-card p { font-size: 0.88rem; color: var(--muted); }
    .project-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; flex-shrink: 0; align-self: stretch; }
    .project-tags { display: flex; flex-wrap: wrap; gap: 6px; justify-content: flex-end; }
    .project-link { font-size: 0.82rem; color: var(--accent); text-decoration: none; white-space: nowrap; }
    .project-link:hover { text-decoration: underline; }
    .project-links { display: flex; flex-wrap: wrap; gap: 6px; justify-content: flex-end; margin-top: auto; }
    .btn-link {
      font-size: 0.78rem;
      padding: 4px 10px;
      border-radius: 6px;
      text-decoration: none;
      border: 0.5px solid var(--border);
      color: var(--muted);
      transition: all .2s;
      white-space: nowrap;
    }
    .btn-link:hover { border-color: var(--accent); color: var(--accent); }
    .btn-link.paper { border-color: rgba(124,111,247,0.4); color: var(--accent); }
    .btn-link.paper:hover { background: rgba(124,111,247,0.1); }
    .btn-link.video { border-color: rgba(93,202,165,0.4); color: var(--accent2); }
    .btn-link.video:hover { background: rgba(93,202,165,0.1); }
    .project-badge {
      font-size: 0.72rem;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(124,111,247,0.15);
      color: var(--accent);
      border: 0.5px solid var(--accent);
      white-space: nowrap;
    }

    /* ── 联系 ── */
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
    }
    .contact-card {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
      text-decoration: none;
      color: var(--text);
      transition: all .2s;
    }
    .contact-card:hover { border-color: var(--accent2); }
    .contact-card .icon { font-size: 1.2rem; margin-bottom: 0.5rem; }
    .contact-card .label { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.25rem; }
    .contact-card .value { font-size: 0.9rem; }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.82rem;
      color: var(--muted);
      border-top: 0.5px solid var(--border);
    }

    @media (max-width: 600px) {
      .tl-item { grid-template-columns: 1fr; gap: 0.25rem; }
      .tl-date { padding-top: 0; }
      nav { padding: 1rem; }
      .nav-links { gap: 1rem; }
      .project-card { flex-direction: column; gap: 1rem; }
      .project-right { align-items: flex-start; }
      .project-tags { justify-content: flex-start; }
    }
  </style>
</head>
